# Environment variables for helix-word2md-ams
# 
# IMPORTANT: Do NOT add values here!
# Source from terraform environment files:
#   source /path/to/ams-eds-terraform/environments/gov-stage.env
#   source /path/to/ams-eds-terraform/environments/commercial-poc.env
#
# BUILD-TIME variables (set by sourcing terraform env):
#   AWS_REGION                    - AWS region for Lambda deployment
#   AWS_PARTITION                 - AWS partition (aws or aws-us-gov)
#   AWS_ACCOUNT_ID                - AWS account ID
#   HLX_AWS_ROLE_NAME             - IAM role name for Lambda
#   HLX_PROD_SERVER_HOST_PAGE     - Preview domain (e.g., gov-aem.page)
#   HLX_PROD_SERVER_HOST_LIVE     - Live domain (e.g., gov-aem.live)
#   HELIX_BUCKET_SUFFIX           - S3 bucket suffix (e.g., "8")
#
# RUNTIME variables (loaded from AWS Secrets Manager at runtime):
#   /helix-deploy/helix3/all:
#     AZURE_HELIX_SERVICE_CLIENT_ID       - Azure service principal client ID
#     AZURE_HELIX_SERVICE_CLIENT_SECRET   - Azure service principal secret
#     CLOUDFLARE_ACCOUNT_ID               - Cloudflare R2 account ID (optional)
#     CLOUDFLARE_R2_ACCESS_KEY_ID         - Cloudflare R2 access key (optional)
#     CLOUDFLARE_R2_SECRET_ACCESS_KEY     - Cloudflare R2 secret (optional)
#     IMAGE_DOWNLOAD_TIMEOUT              - Timeout for image downloads (optional, default 10000ms)
