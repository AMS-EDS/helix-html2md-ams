# Environment variables for helix-admin-ams
# 
# IMPORTANT: Do NOT add values here!
# Source from terraform environment files:
#   source /path/to/ams-eds-terraform/environments/gov-stage.env
#   source /path/to/ams-eds-terraform/environments/commercial-poc.env
#
# BUILD-TIME variables (set by sourcing terraform env):
#   AWS_REGION                    - AWS region for Lambda deployment
#   AWS_PARTITION                 - AWS partition (aws or aws-us-gov)
#   AWS_ACCOUNT_ID                - AWS account ID
#   HLX_AWS_ROLE_NAME             - IAM role name for Lambda
#   HLX_PROD_SERVER_HOST_PAGE     - Preview domain (e.g., gov-aem.page)
#   HLX_PROD_SERVER_HOST_LIVE     - Live domain (e.g., gov-aem.live)
#   HLX_PROD_SERVER_HOST_REVIEW   - Review domain (e.g., gov-aem.page)
#   DA_DOMAIN                     - Admin domain (e.g., stg.ssa-da.live)
#   DA_DOMAIN_CONTENT             - Content domain (e.g., stg-content.ssa-da.live)
#   HELIX_BUCKET_SUFFIX           - S3 bucket suffix (e.g., "8")
#
# RUNTIME variables (loaded from AWS Secrets Manager at runtime):
#   /helix-deploy/helix3/all (shared across all services):
#     HELIX_BUCKET_NAMES                  - JSON map of bucket names
#     AZURE_HELIX_SERVICE_CLIENT_ID       - Azure service principal client ID
#     AZURE_HELIX_SERVICE_CLIENT_SECRET   - Azure service principal secret
#     CLOUDFLARE_ACCOUNT_ID               - Cloudflare account ID
#     CLOUDFLARE_R2_ACCESS_KEY_ID         - Cloudflare R2 access key
#     CLOUDFLARE_R2_SECRET_ACCESS_KEY     - Cloudflare R2 secret
#     CLOUDFLARE_PURGE_TOKEN              - Cloudflare cache purge token
#     AZURE_WORD2MD_CLIENT_ID             - Azure Word2MD client ID
#     AZURE_WORD2MD_CLIENT_SECRET         - Azure Word2MD secret
#     AZURE_WORD2MD_TENANT                - Azure Word2MD tenant
#     AZURE_BOT_APP_ID                    - Azure bot app ID
#     AZURE_BOT_APP_PASSWORD              - Azure bot password
#     GITHUB_APP_ID                       - GitHub App ID
#     GITHUB_APP_PRIVATE_KEY              - GitHub App private key
#     GOOGLE_DOCS2MD_CLIENT_EMAIL         - Google service account email
#     GOOGLE_DOCS2MD_PRIVATE_KEY          - Google service account key
#     HLX_TEST_HEADERS                    - Test headers JSON
#
#   /helix-deploy/helix3/admin (admin-specific):
#     HLX_ADMIN_IDP_PRIVATE_KEY           - Admin IDP private key
#     HLX_ADMIN_APP_AZURE_CLIENT_ID       - Admin Azure client ID
#     HLX_ADMIN_APP_AZURE_CLIENT_SECRET   - Admin Azure secret
#     HLX_ADMIN_CLOUDFLARE_ACCOUNT_ID     - Admin Cloudflare account
#     HLX_ADMIN_CLOUDFLARE_API_TOKEN      - Admin Cloudflare token
#     HLX_CONFIG_SERVICE_TOKEN            - Config service token
